# Normalize line endings to LF across platforms.
* text=auto eol=lf

# Keep the installed package to what Sublime actually loads. Package Control
# installs from the GitHub archive for a tag, and GitHub honours export-ignore
# when it builds that archive — so development files never reach users.
/.github        export-ignore
/tests          export-ignore
/.gitattributes export-ignore
/.gitignore     export-ignore
